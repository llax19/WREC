+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""WREC-guided residency hints for the real weight offloader.
+
+WREC decisions are expert-granular, while vLLM's current prefetch offloader is
+module/layer-granular. This state object bridges the two conservatively: any
+admitted expert marks its layer as desirable for prefetch. The offloader still
+owns the real H2D copy and buffer residency.
+"""
+
+from __future__ import annotations
+
+import os
+from collections import Counter, deque
+from typing import Any
+
+
+def _env_bool(name: str, default: bool = False) -> bool:
+    value = os.getenv(name)
+    if value is None or value == "":
+        return default
+    return value.lower() in ("1", "true", "yes", "on")
+
+
+class WrecResidencyState:
+    def __init__(self) -> None:
+        self.enabled = _env_bool("WREC_RESIDENCY_MANAGER", False)
+        self.desired_layer_counts: Counter[int] = Counter()
+        self.recent_layers: deque[int] = deque(maxlen=256)
+
+    def record_sidecar_response(self, response: dict[str, Any] | None) -> None:
+        if not self.enabled or not response:
+            return
+        decisions = response.get("decisions")
+        if not isinstance(decisions, list):
+            return
+        for decision in decisions:
+            if not isinstance(decision, dict):
+                continue
+            layer = decision.get("layer")
+            if layer is None:
+                continue
+            layer_id = int(layer)
+            if decision.get("would_admit"):
+                self.desired_layer_counts[layer_id] += 1
+                self.recent_layers.append(layer_id)
+
+            evicted = decision.get("would_evict")
+            if isinstance(evicted, (list, tuple)) and evicted:
+                evicted_layer = int(evicted[0])
+                if self.desired_layer_counts[evicted_layer] > 0:
+                    self.desired_layer_counts[evicted_layer] -= 1
+                    if self.desired_layer_counts[evicted_layer] <= 0:
+                        del self.desired_layer_counts[evicted_layer]
+
+    def choose_next_prefetch_index(
+        self,
+        *,
+        default_index: int,
+        module_offloaders: list[Any],
+    ) -> int:
+        if not self.enabled or not module_offloaders or not self.desired_layer_counts:
+            return default_index
+
+        layer_to_index = {
+            int(getattr(offloader, "model_layer_index", -1)): index
+            for index, offloader in enumerate(module_offloaders)
+        }
+        while self.recent_layers:
+            layer = self.recent_layers.pop()
+            if layer in layer_to_index and self.desired_layer_counts[layer] > 0:
+                return layer_to_index[layer]
+        return default_index
+
+
+_GLOBAL_WREC_RESIDENCY_STATE = WrecResidencyState()
+
+
+def get_wrec_residency_state() -> WrecResidencyState:
+    return _GLOBAL_WREC_RESIDENCY_STATE
