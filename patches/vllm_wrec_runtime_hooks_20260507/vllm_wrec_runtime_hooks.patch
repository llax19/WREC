diff --git a/vllm/model_executor/layers/fused_moe/wrec_expert_residency.py b/vllm/model_executor/layers/fused_moe/wrec_expert_residency.py
new file mode 100644
index 0000000..b046ee1
--- /dev/null
+++ b/vllm/model_executor/layers/fused_moe/wrec_expert_residency.py
@@ -0,0 +1,418 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+
+from dataclasses import dataclass, field
+import os
+import re
+from typing import Any
+
+import torch
+
+from vllm.logger import init_logger
+
+logger = init_logger(__name__)
+
+
+def _env_bool(name: str, default: bool = False) -> bool:
+    value = os.getenv(name)
+    if value is None:
+        return default
+    return value.lower() in ("1", "true", "yes", "on")
+
+
+@dataclass
+class _LayerResidencyState:
+    cpu_w13_weight: torch.Tensor
+    cpu_w2_weight: torch.Tensor
+    resident_experts: set[int] = field(default_factory=set)
+    finite_slots: bool = False
+    expert_map: torch.Tensor | None = None
+    logical_to_slot: dict[int, int] = field(default_factory=dict)
+    slot_to_logical: list[int | None] = field(default_factory=list)
+
+
+class WrecExpertResidencyManager:
+    """Experimental expert-slice residency hook for FusedMoE.
+
+    With WREC_EXPERT_RESIDENCY_SLOT_CAPACITY unset or 0, this stays in a
+    state-only mode by default: sidecar decisions are recorded, but full expert
+    CPU backing is not duplicated. Set WREC_EXPERT_RESIDENCY_ROW_COPY=1 to
+    enable the old full-shape row-copy skeleton. When
+    WREC_EXPERT_RESIDENCY_SLOT_CAPACITY is set below the model's global expert
+    count, the manager replaces the layer weights with finite GPU slot tensors
+    and exposes a global-logical-expert to slot expert_map for the MoE kernel.
+    """
+
+    def __init__(self) -> None:
+        self.enabled = _env_bool("WREC_EXPERT_RESIDENCY", False)
+        self.max_experts_per_layer = int(
+            os.getenv("WREC_EXPERT_RESIDENCY_MAX_EXPERTS_PER_LAYER", "0")
+        )
+        self.slot_capacity = int(
+            os.getenv("WREC_EXPERT_RESIDENCY_SLOT_CAPACITY", "0")
+        )
+        self.row_copy_full_tensor = _env_bool(
+            "WREC_EXPERT_RESIDENCY_ROW_COPY", False
+        )
+        self._layers: dict[int, _LayerResidencyState] = {}
+        self._layers_by_model_index: dict[int, _LayerResidencyState] = {}
+        self._desired_experts_by_layer: dict[int, dict[int, int]] = {}
+        self._warned_unsupported: set[int] = set()
+
+    def maybe_onload_selected_experts(
+        self,
+        layer: Any,
+        router_logits: torch.Tensor,
+    ) -> None:
+        if not self.enabled:
+            return
+        if not self._supports_layer(layer):
+            layer_id = id(layer)
+            if layer_id not in self._warned_unsupported:
+                self._warned_unsupported.add(layer_id)
+                logger.warning(
+                    "WREC expert residency disabled for unsupported FusedMoE layer %s",
+                    getattr(layer, "layer_name", "<unknown>"),
+                )
+            return
+
+        current_experts = self._select_experts(layer, router_logits)
+        if not current_experts:
+            return
+
+        selected_experts = self._selected_experts_for_layer(layer)
+        selected_experts.extend(current_experts)
+        selected_experts = list(dict.fromkeys(selected_experts))
+
+        state = self._get_or_create_layer_state(layer, current_experts)
+        if not state.finite_slots and not self.row_copy_full_tensor:
+            return
+        selected_experts = self._bounded_prefetch_experts(
+            layer=layer,
+            state=state,
+            selected_experts=selected_experts,
+            current_experts=current_experts,
+        )
+        self._onload_experts(layer, state, selected_experts)
+
+    def record_sidecar_response(self, response: dict[str, Any] | None) -> None:
+        if not self.enabled or not response:
+            return
+        decisions = response.get("decisions")
+        if not isinstance(decisions, list):
+            return
+        for decision in decisions:
+            if not isinstance(decision, dict):
+                continue
+            layer = decision.get("layer")
+            expert = decision.get("expert")
+            if layer is None or expert is None:
+                continue
+            layer_id = int(layer)
+            expert_id = int(expert)
+            if decision.get("would_admit"):
+                self._increment_desired_expert(layer_id, expert_id)
+
+            evicted = decision.get("would_evict")
+            if isinstance(evicted, (list, tuple)) and len(evicted) >= 2:
+                evicted_layer = int(evicted[0])
+                evicted_expert = int(evicted[1])
+                self._decrement_desired_expert(evicted_layer, evicted_expert)
+                state = self._layers_by_model_index.get(evicted_layer)
+                if state is not None and state.finite_slots:
+                    self._evict_expert(state, evicted_expert)
+
+    def expert_map_for_layer(self, layer: Any) -> torch.Tensor | None:
+        if not self.enabled:
+            return None
+        state = self._layers.get(id(layer))
+        if state is None or not state.finite_slots:
+            return None
+        return state.expert_map
+
+    def _supports_layer(self, layer: Any) -> bool:
+        w13_weight = getattr(layer, "w13_weight", None)
+        w2_weight = getattr(layer, "w2_weight", None)
+        if not isinstance(w13_weight, torch.Tensor):
+            return False
+        if not isinstance(w2_weight, torch.Tensor):
+            return False
+        if w13_weight.ndim != 3 or w2_weight.ndim != 3:
+            return False
+        if w13_weight.shape[0] != w2_weight.shape[0]:
+            return False
+        if getattr(layer, "enable_eplb", False):
+            return False
+        if int(getattr(layer, "ep_size", 1)) != 1:
+            return False
+        if int(getattr(layer, "num_fused_shared_experts", 0)) != 0:
+            return False
+        if getattr(layer, "rocm_aiter_fmoe_enabled", False):
+            return False
+        if hasattr(layer, "w13_bias") or hasattr(layer, "w2_bias"):
+            return False
+        if getattr(layer, "custom_routing_function", None) is not None:
+            return False
+        if getattr(layer, "use_grouped_topk", False):
+            return False
+        if getattr(layer, "scoring_func", "softmax") != "softmax":
+            return False
+        global_num_experts = getattr(layer, "global_num_experts", None)
+        state = self._layers.get(id(layer))
+        if state is not None and state.finite_slots:
+            return True
+        if global_num_experts is not None and w13_weight.shape[0] < global_num_experts:
+            return False
+        return True
+
+    def _select_experts(self, layer: Any, router_logits: torch.Tensor) -> list[int]:
+        if router_logits.numel() == 0:
+            return []
+        if router_logits.ndim < 2:
+            return []
+
+        top_k = min(int(getattr(layer, "top_k", 1)), router_logits.shape[-1])
+        if top_k <= 0:
+            return []
+
+        with torch.no_grad():
+            topk_ids = torch.topk(router_logits.float(), k=top_k, dim=-1).indices
+            unique_ids = torch.unique(topk_ids.detach().cpu(), sorted=True)
+
+        num_experts = int(getattr(layer, "global_num_experts", router_logits.shape[-1]))
+        return [
+            int(expert_id)
+            for expert_id in unique_ids.tolist()
+            if 0 <= int(expert_id) < num_experts
+        ]
+
+    def _selected_experts_for_layer(self, layer: Any) -> list[int]:
+        layer_index = self._layer_index(layer)
+        if layer_index is None:
+            return []
+        desired = self._desired_experts_by_layer.get(layer_index)
+        if not desired:
+            return []
+        return [
+            expert_id
+            for expert_id, count in sorted(desired.items())
+            if count > 0
+        ]
+
+    def _layer_index(self, layer: Any) -> int | None:
+        layer_name = getattr(layer, "layer_name", None)
+        if not isinstance(layer_name, str):
+            return None
+        match = re.search(r"(?:^|\.)layers\.(\d+)(?:\.|$)", layer_name)
+        if match is None:
+            return None
+        return int(match.group(1))
+
+    def _increment_desired_expert(self, layer_id: int, expert_id: int) -> None:
+        experts = self._desired_experts_by_layer.setdefault(layer_id, {})
+        experts[expert_id] = experts.get(expert_id, 0) + 1
+
+    def _decrement_desired_expert(self, layer_id: int, expert_id: int) -> None:
+        experts = self._desired_experts_by_layer.get(layer_id)
+        if not experts:
+            return
+        if experts.get(expert_id, 0) <= 1:
+            experts.pop(expert_id, None)
+        else:
+            experts[expert_id] -= 1
+        if not experts:
+            self._desired_experts_by_layer.pop(layer_id, None)
+
+    def _get_or_create_layer_state(
+        self,
+        layer: Any,
+        current_experts: list[int],
+    ) -> _LayerResidencyState:
+        layer_id = id(layer)
+        state = self._layers.get(layer_id)
+        if state is not None:
+            return state
+
+        finite_slots = self._use_finite_slots(layer)
+        if not finite_slots and not self.row_copy_full_tensor:
+            state = _LayerResidencyState(
+                cpu_w13_weight=torch.empty(0),
+                cpu_w2_weight=torch.empty(0),
+            )
+            self._layers[layer_id] = state
+            layer_index = self._layer_index(layer)
+            if layer_index is not None:
+                self._layers_by_model_index[layer_index] = state
+            return state
+        if finite_slots and len(current_experts) > self.slot_capacity:
+            raise RuntimeError(
+                "WREC expert residency slot overflow before initialization: "
+                f"{len(current_experts)} experts needed but capacity is "
+                f"{self.slot_capacity} for layer {getattr(layer, 'layer_name', '<unknown>')}"
+            )
+
+        with torch.no_grad():
+            state = _LayerResidencyState(
+                cpu_w13_weight=self._cpu_backing_for_weight(layer.w13_weight),
+                cpu_w2_weight=self._cpu_backing_for_weight(layer.w2_weight),
+            )
+            if finite_slots:
+                self._install_finite_slot_tensors(layer, state)
+        self._layers[layer_id] = state
+        layer_index = self._layer_index(layer)
+        if layer_index is not None:
+            self._layers_by_model_index[layer_index] = state
+        logger.info(
+            "WREC expert residency created CPU backing for FusedMoE layer %s",
+            getattr(layer, "layer_name", "<unknown>"),
+        )
+        return state
+
+    def _cpu_backing_for_weight(self, weight: torch.Tensor) -> torch.Tensor:
+        offload_storage = getattr(weight, "_vllm_cpu_offload_storage", None)
+        if (
+            isinstance(offload_storage, torch.Tensor)
+            and offload_storage.device.type == "cpu"
+            and offload_storage.shape == weight.shape
+            and offload_storage.dtype == weight.dtype
+        ):
+            return offload_storage.detach()
+        return weight.detach().to("cpu", copy=True)
+
+    def _use_finite_slots(self, layer: Any) -> bool:
+        global_num_experts = int(getattr(layer, "global_num_experts", 0))
+        return 0 < self.slot_capacity < global_num_experts
+
+    def _install_finite_slot_tensors(
+        self,
+        layer: Any,
+        state: _LayerResidencyState,
+    ) -> None:
+        slot_capacity = self.slot_capacity
+        w13_slots = torch.empty(
+            (slot_capacity, *state.cpu_w13_weight.shape[1:]),
+            dtype=layer.w13_weight.dtype,
+            device=layer.w13_weight.device,
+        )
+        w2_slots = torch.empty(
+            (slot_capacity, *state.cpu_w2_weight.shape[1:]),
+            dtype=layer.w2_weight.dtype,
+            device=layer.w2_weight.device,
+        )
+        layer.w13_weight = torch.nn.Parameter(w13_slots, requires_grad=False)
+        layer.w2_weight = torch.nn.Parameter(w2_slots, requires_grad=False)
+
+        global_num_experts = int(getattr(layer, "global_num_experts"))
+        state.finite_slots = True
+        state.expert_map = torch.full(
+            (global_num_experts,),
+            -1,
+            dtype=torch.int32,
+            device=w13_slots.device,
+        )
+        state.slot_to_logical = [None for _ in range(slot_capacity)]
+
+    def _bounded_prefetch_experts(
+        self,
+        *,
+        layer: Any,
+        state: _LayerResidencyState,
+        selected_experts: list[int],
+        current_experts: list[int],
+    ) -> list[int]:
+        if not state.finite_slots:
+            if self.max_experts_per_layer > 0:
+                return selected_experts[: self.max_experts_per_layer]
+            return selected_experts
+
+        if len(current_experts) > self.slot_capacity:
+            raise RuntimeError(
+                "WREC expert residency slot overflow: "
+                f"{len(current_experts)} experts needed but capacity is "
+                f"{self.slot_capacity} for layer {getattr(layer, 'layer_name', '<unknown>')}"
+            )
+
+        bounded = list(current_experts)
+        for expert_id in selected_experts:
+            if len(bounded) >= self.slot_capacity:
+                break
+            if expert_id not in bounded:
+                bounded.append(expert_id)
+        return bounded
+
+    def _onload_experts(
+        self,
+        layer: Any,
+        state: _LayerResidencyState,
+        expert_ids: list[int],
+    ) -> None:
+        with torch.no_grad():
+            for expert_id in expert_ids:
+                if expert_id in state.resident_experts:
+                    continue
+                if state.finite_slots:
+                    slot_id = self._slot_for_onload(state, expert_id, expert_ids)
+                    layer.w13_weight[slot_id].copy_(
+                        state.cpu_w13_weight[expert_id],
+                        non_blocking=True,
+                    )
+                    layer.w2_weight[slot_id].copy_(
+                        state.cpu_w2_weight[expert_id],
+                        non_blocking=True,
+                    )
+                    state.logical_to_slot[expert_id] = slot_id
+                    state.slot_to_logical[slot_id] = expert_id
+                    assert state.expert_map is not None
+                    state.expert_map[expert_id] = slot_id
+                    state.resident_experts.add(expert_id)
+                else:
+                    layer.w13_weight[expert_id].copy_(
+                        state.cpu_w13_weight[expert_id],
+                        non_blocking=True,
+                    )
+                    layer.w2_weight[expert_id].copy_(
+                        state.cpu_w2_weight[expert_id],
+                        non_blocking=True,
+                    )
+                    state.resident_experts.add(expert_id)
+
+    def _slot_for_onload(
+        self,
+        state: _LayerResidencyState,
+        expert_id: int,
+        protected_experts: list[int],
+    ) -> int:
+        if expert_id in state.logical_to_slot:
+            return state.logical_to_slot[expert_id]
+
+        for slot_id, logical_id in enumerate(state.slot_to_logical):
+            if logical_id is None:
+                return slot_id
+
+        protected = set(protected_experts)
+        for slot_id, logical_id in enumerate(state.slot_to_logical):
+            if logical_id is not None and logical_id not in protected:
+                self._evict_expert(state, logical_id)
+                return slot_id
+
+        raise RuntimeError(
+            "WREC expert residency cannot find a free GPU expert slot. "
+            f"capacity={len(state.slot_to_logical)}, protected={sorted(protected)}"
+        )
+
+    def _evict_expert(self, state: _LayerResidencyState, expert_id: int) -> None:
+        slot_id = state.logical_to_slot.pop(expert_id, None)
+        if slot_id is None:
+            return
+        if 0 <= slot_id < len(state.slot_to_logical):
+            state.slot_to_logical[slot_id] = None
+        if state.expert_map is not None:
+            state.expert_map[expert_id] = -1
+        state.resident_experts.discard(expert_id)
+
+
+_WREC_EXPERT_RESIDENCY_MANAGER = WrecExpertResidencyManager()
+
+
+def get_wrec_expert_residency_manager() -> WrecExpertResidencyManager:
+    return _WREC_EXPERT_RESIDENCY_MANAGER
