+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Optional WREC sidecar bridge for routed expert events.
+
+This bridge is intentionally fail-open and disabled unless WREC_SIDECAR_URL is
+set. It exports routed expert arrays using the same event contract as the WREC
+runtime sidecar prototype.
+"""
+
+from __future__ import annotations
+
+import http.client
+import json
+import logging
+import os
+from urllib.parse import urlparse
+
+import numpy as np
+
+from vllm.model_executor.layers.fused_moe.wrec_expert_residency import (
+    get_wrec_expert_residency_manager,
+)
+from vllm.model_executor.offloader.wrec_residency import get_wrec_residency_state
+
+logger = logging.getLogger(__name__)
+
+
+class WrecSidecarClient:
+    """Best-effort HTTP client for WREC routed expert events."""
+
+    def __init__(self) -> None:
+        self.url = os.getenv("WREC_SIDECAR_URL", "")
+        self.enabled = bool(self.url)
+        self.timeout = float(os.getenv("WREC_SIDECAR_TIMEOUT_SECONDS", "0.05"))
+        self.max_events_per_request = int(
+            os.getenv("WREC_SIDECAR_MAX_EVENTS_PER_REQUEST", "0")
+        )
+        self._event_index = 0
+        self._disabled_after_error = bool(
+            int(os.getenv("WREC_SIDECAR_DISABLE_AFTER_ERROR", "1"))
+        )
+        self._conn: http.client.HTTPConnection | None = None
+        self._path = "/event"
+
+        if not self.enabled:
+            return
+
+        parsed = urlparse(self.url)
+        host = parsed.hostname or "127.0.0.1"
+        port = parsed.port or 80
+        self._path = parsed.path or "/event"
+        self._conn = http.client.HTTPConnection(host, port, timeout=self.timeout)
+        logger.info("WREC sidecar event bridge enabled: %s", self.url)
+
+    def submit_routed_experts(
+        self,
+        *,
+        request_id: str,
+        routed_experts: np.ndarray | None,
+    ) -> None:
+        if not self.enabled or routed_experts is None:
+            return
+        if self._conn is None:
+            return
+
+        array = np.asarray(routed_experts)
+        if array.ndim != 3:
+            logger.warning("WREC sidecar skipped unexpected shape: %s", array.shape)
+            return
+
+        sent = 0
+        try:
+            seq_len, num_layers, _topk = array.shape
+            for token_pos in range(int(seq_len)):
+                for layer in range(int(num_layers)):
+                    selected = [
+                        int(expert)
+                        for expert in array[token_pos, layer].tolist()
+                        if int(expert) >= 0
+                    ]
+                    if not selected:
+                        continue
+                    if (
+                        self.max_events_per_request > 0
+                        and sent >= self.max_events_per_request
+                    ):
+                        return
+                    payload = {
+                        "request_id": request_id,
+                        "event_index": self._event_index,
+                        "layer": layer,
+                        "token_pos": token_pos,
+                        "selected_experts": selected,
+                    }
+                    body = json.dumps(payload).encode("utf-8")
+                    self._conn.request(
+                        "POST",
+                        self._path,
+                        body=body,
+                        headers={"Content-Type": "application/json"},
+                    )
+                    response = self._conn.getresponse()
+                    raw = response.read()
+                    if response.status >= 400:
+                        raise RuntimeError(f"WREC sidecar HTTP {response.status}")
+                    if raw:
+                        response_payload = json.loads(raw.decode("utf-8"))
+                        get_wrec_residency_state().record_sidecar_response(
+                            response_payload
+                        )
+                        get_wrec_expert_residency_manager().record_sidecar_response(
+                            response_payload
+                        )
+                    self._event_index += 1
+                    sent += 1
+        except Exception:
+            logger.warning("WREC sidecar bridge failed", exc_info=True)
+            if self._disabled_after_error:
+                self.enabled = False
+                if self._conn is not None:
+                    self._conn.close()
+                    self._conn = None
